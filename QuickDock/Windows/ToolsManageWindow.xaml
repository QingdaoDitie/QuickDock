<Window x:Class="QuickDock.Windows.ToolsManageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="工具管理"
        Width="660"
        Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Topmost="True"
        Style="{StaticResource WindowStyle}">
    
    <Grid Margin="18">
        <Border Style="{StaticResource DialogPanelStyle}">
            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,14">
                    <TextBlock x:Name="HeaderTitleText"
                               Text="工具管理"
                               Style="{StaticResource DialogTitleTextStyle}"/>
                    <TextBlock x:Name="HeaderSubtitleText"
                               Text="确认主程序、调整顺序并清理无效工具。"
                               Style="{StaticResource DialogSubtitleTextStyle}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Border Grid.Row="1"
                        Style="{StaticResource DialogCardStyle}"
                        Padding="0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="14">
                        <StackPanel x:Name="ToolsListPanel"/>
                    </ScrollViewer>
                </Border>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,16,0,0">
                    <Button x:Name="SaveManageButton"
                            Content="保存"
                            Width="96"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Click="OnSaveClick"
                            Margin="0,0,10,0"/>
                    <Button x:Name="CancelManageButton"
                            Content="取消"
                            Width="96"
                            Style="{StaticResource SettingsButtonStyle}"
                            Click="OnCancelClick"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
