<Window x:Class="QuickDock.Windows.ToolsManageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="工具管理"
        Width="660"
        Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Topmost="True"
        Style="{StaticResource WindowStyle}">
    
    <Grid Margin="18">
        <Border Style="{StaticResource DialogPanelStyle}">
            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,14">
                    <TextBlock x:Name="HeaderTitleText"
                               Text="工具管理"
                               Style="{StaticResource DialogTitleTextStyle}"/>
                    <TextBlock x:Name="HeaderSubtitleText"
                               Text="确认主程序、调整顺序并清理无效工具。"
                               Style="{StaticResource DialogSubtitleTextStyle}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel x:Name="PendingPanel" Grid.Row="0" Margin="0,0,0,10" Visibility="Collapsed"/>

                    <Border Grid.Row="1" Background="{StaticResource WindowCardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                        <ListBox x:Name="ToolsListBox"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource TextBrush}"
                                 SelectionMode="Single"
                                 PreviewMouseLeftButtonDown="OnToolDragStart"
                                 PreviewMouseMove="OnToolDragging"
                                 AllowDrop="True"
                                 DragOver="OnToolDragOver"
                                 Drop="OnToolDrop"
                                 MouseDoubleClick="OnToolDoubleClick"
                                 Padding="2">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="2,1"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="ItemBd" Background="Transparent" CornerRadius="3" Padding="6,5">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemBd" Property="Background" Value="{StaticResource HoverBackgroundBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="ItemBd" Property="Background" Value="{StaticResource HoverBackgroundBrush}"/>
                                                        <Setter TargetName="ItemBd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                        <Setter TargetName="ItemBd" Property="BorderThickness" Value="1"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="22" Height="22" Background="{StaticResource SecondaryBackgroundBrush}" CornerRadius="3" Margin="2,0,4,0" VerticalAlignment="Center">
                                            <TextBlock Text="::" FontSize="10" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}" FontSize="12" Foreground="{StaticResource TextBrush}"/>
                                            <TextBlock Text="{Binding ExePath}" FontSize="10" Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis" MaxWidth="420"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="x" FontSize="11" FontWeight="Bold"
                                                Style="{StaticResource SettingsButtonStyle}"
                                                Padding="6,2"
                                                VerticalAlignment="Center"
                                                Click="OnRemoveToolClick"
                                                Tag="{Binding}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,16,0,0">
                    <Button x:Name="SaveManageButton"
                            Content="保存"
                            Width="96"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Click="OnSaveClick"
                            Margin="0,0,10,0"/>
                    <Button x:Name="CancelManageButton"
                            Content="取消"
                            Width="96"
                            Style="{StaticResource SettingsButtonStyle}"
                            Click="OnCancelClick"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
