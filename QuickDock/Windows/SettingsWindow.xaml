<Window x:Class="QuickDock.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QuickDock Settings"
        Width="500"
        Height="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Topmost="True"
        Style="{StaticResource WindowStyle}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   x:Name="DockItemsLabel"
                   Text="Dock Items" 
                   FontSize="16" 
                   FontWeight="Bold"
                   Foreground="{StaticResource TextBrush}"
                   Margin="0,0,0,10"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ListBox x:Name="ItemsListBox"
                     Grid.Column="0"
                     Background="{StaticResource SecondaryBackgroundBrush}"
                     BorderBrush="{StaticResource BorderBrush}"
                     Foreground="{StaticResource TextBrush}"
                     SelectionMode="Single"
                     DisplayMemberPath="Name"
                     SelectionChanged="OnItemSelected"/>

            <StackPanel Grid.Column="1" Margin="10,0,0,0" Width="80">
                <Button x:Name="AddButton"
                        Content="Add" 
                        Style="{StaticResource SettingsButtonStyle}"
                        Click="OnAddClick"
                        Margin="0,0,0,5"/>
                <Button x:Name="EditButton"
                        Content="Edit" 
                        Style="{StaticResource SettingsButtonStyle}"
                        Click="OnEditClick"
                        Margin="0,0,0,5"
                        IsEnabled="False"/>
                <Button x:Name="DeleteButton"
                        Content="Delete" 
                        Style="{StaticResource SettingsButtonStyle}"
                        Click="OnDeleteClick"
                        Margin="0,0,0,5"
                        IsEnabled="False"/>
                <Separator Background="{StaticResource BorderBrush}" Margin="0,5"/>
                <Button x:Name="UpButton"
                        Content="Up" 
                        Style="{StaticResource SettingsButtonStyle}"
                        Click="OnMoveUpClick"
                        Margin="0,0,0,5"
                        IsEnabled="False"/>
                <Button x:Name="DownButton"
                        Content="Down" 
                        Style="{StaticResource SettingsButtonStyle}"
                        Click="OnMoveDownClick"
                        IsEnabled="False"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <CheckBox Grid.Column="0"
                      x:Name="AutoStartCheckBox"
                      Content="Start with Windows" 
                      Style="{StaticResource CheckBoxStyle}"
                      Checked="OnAutoStartChanged"
                      Unchecked="OnAutoStartChanged"
                      VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" 
                       x:Name="LanguageLabel"
                       Text="Language:" 
                       VerticalAlignment="Center"
                       Style="{StaticResource TextBlockStyle}"
                       Margin="0,0,10,0"/>
            <ComboBox Grid.Column="1"
                      x:Name="LanguageComboBox"
                      Style="{StaticResource ComboBoxStyle}"
                      SelectionChanged="OnLanguageChanged"/>
        </Grid>

        <Grid Grid.Row="4" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" 
                       x:Name="BackgroundColorLabel"
                       Text="Background:" 
                       VerticalAlignment="Center"
                       Style="{StaticResource TextBlockStyle}"
                       Margin="0,0,10,0"/>
            <TextBox Grid.Column="1"
                     x:Name="BackgroundColorTextBox"
                     Style="{StaticResource TextBoxStyle}"
                     Text="#1e1e1e"
                     VerticalAlignment="Center"
                     TextChanged="OnBackgroundColorChanged"/>
            <Border Grid.Column="2"
                    x:Name="BackgroundColorPreview"
                    Width="30"
                    Height="25"
                    Background="#1e1e1e"
                    CornerRadius="3"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="5" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" 
                       x:Name="OpacityLabel"
                       Text="Opacity:" 
                       VerticalAlignment="Center"
                       Style="{StaticResource TextBlockStyle}"
                       Margin="0,0,10,0"/>
            <Slider Grid.Column="1"
                    x:Name="OpacitySlider"
                    Minimum="0.3"
                    Maximum="1.0"
                    TickFrequency="0.1"
                    IsSnapToTickEnabled="True"
                    VerticalAlignment="Center"
                    ValueChanged="OnOpacityChanged"/>
            <TextBlock Grid.Column="2"
                       x:Name="OpacityValue"
                       Text="90%"
                       VerticalAlignment="Center"
                       Style="{StaticResource TextBlockStyle}"
                       Margin="10,0,0,0"
                       Width="40"/>
        </Grid>

        <Grid Grid.Row="6" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" 
                       x:Name="ScaleLabel"
                       Text="Scale:" 
                       VerticalAlignment="Center"
                       Style="{StaticResource TextBlockStyle}"
                       Margin="0,0,10,0"/>
            <Slider Grid.Column="1"
                    x:Name="ScaleSlider"
                    Minimum="0.5"
                    Maximum="2.0"
                    TickFrequency="0.1"
                    IsSnapToTickEnabled="True"
                    VerticalAlignment="Center"
                    ValueChanged="OnScaleChanged"/>
            <TextBlock Grid.Column="2"
                       x:Name="ScaleValue"
                       Text="100%"
                       VerticalAlignment="Center"
                       Style="{StaticResource TextBlockStyle}"
                       Margin="10,0,0,0"
                       Width="40"/>
        </Grid>

        <Grid Grid.Row="7" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" 
                       x:Name="IconSizeLabel"
                       Text="Icon Size:" 
                       VerticalAlignment="Center"
                       Style="{StaticResource TextBlockStyle}"
                       Margin="0,0,10,0"/>
            <Slider Grid.Column="1"
                    x:Name="IconSizeSlider"
                    Minimum="16"
                    Maximum="64"
                    TickFrequency="4"
                    IsSnapToTickEnabled="True"
                    VerticalAlignment="Center"
                    ValueChanged="OnIconSizeChanged"/>
            <TextBlock Grid.Column="2"
                       x:Name="IconSizeValue"
                       Text="32px"
                       VerticalAlignment="Center"
                       Style="{StaticResource TextBlockStyle}"
                       Margin="10,0,0,0"
                       Width="40"/>
        </Grid>

        <Grid Grid.Row="8" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" 
                       x:Name="IconSpacingLabel"
                       Text="Icon Spacing:" 
                       VerticalAlignment="Center"
                       Style="{StaticResource TextBlockStyle}"
                       Margin="0,0,10,0"/>
            <Slider Grid.Column="1"
                    x:Name="IconSpacingSlider"
                    Minimum="0"
                    Maximum="20"
                    TickFrequency="1"
                    IsSnapToTickEnabled="True"
                    VerticalAlignment="Center"
                    ValueChanged="OnIconSpacingChanged"/>
            <TextBlock Grid.Column="2"
                       x:Name="IconSpacingValue"
                       Text="5px"
                       VerticalAlignment="Center"
                       Style="{StaticResource TextBlockStyle}"
                       Margin="10,0,0,0"
                       Width="40"/>
        </Grid>

        <Grid Grid.Row="9" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <CheckBox Grid.Column="0"
                      x:Name="ShowStatusBarCheckBox"
                      Content="Show Status Bar" 
                      Style="{StaticResource CheckBoxStyle}"
                      Checked="OnShowStatusBarChanged"
                      Unchecked="OnShowStatusBarChanged"
                      VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="10" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" 
                       x:Name="WeatherCityLabel"
                       Text="Weather City:" 
                       VerticalAlignment="Center"
                       Style="{StaticResource TextBlockStyle}"
                       Margin="0,0,10,0"/>
            <TextBox Grid.Column="1"
                     x:Name="WeatherCityTextBox"
                     Style="{StaticResource TextBoxStyle}"
                     VerticalAlignment="Center"
                     TextChanged="OnWeatherCityChanged"/>
        </Grid>

        <StackPanel Grid.Row="11" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button x:Name="SaveButton"
                    Content="Save" 
                    Style="{StaticResource SettingsButtonStyle}"
                    Click="OnSaveClick"
                    Margin="0,0,10,0"/>
            <Button x:Name="CancelButton"
                    Content="Cancel" 
                    Style="{StaticResource SettingsButtonStyle}"
                    Click="OnCancelClick"/>
        </StackPanel>
    </Grid>
</Window>
