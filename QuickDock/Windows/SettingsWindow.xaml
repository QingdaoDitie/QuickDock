<Window x:Class="QuickDock.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QuickDock Settings"
        Width="500"
        Height="860"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Topmost="True"
        Background="White">
    
    <Window.Resources>
        <Style x:Key="SettingsButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#e8e8e8"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#ccc"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#d0d0d0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#f5f5f5"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="BorderBrush" Value="#ccc"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#f5f5f5"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="BorderBrush" Value="#ccc"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   x:Name="DockItemsLabel"
                   Text="Dock Items" 
                   FontSize="16" 
                   FontWeight="Bold"
                   Foreground="#333"
                   Margin="0,0,0,10"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ListBox x:Name="ItemsListBox"
                     Grid.Column="0"
                     Background="#f5f5f5"
                     BorderBrush="#ddd"
                     Foreground="#333"
                     SelectionMode="Single"
                     DisplayMemberPath="Name"
                     SelectionChanged="OnItemSelected"/>

            <StackPanel Grid.Column="1" Margin="10,0,0,0" Width="80">
                <Button x:Name="AddButton"
                        Content="Add" 
                        Style="{StaticResource SettingsButtonStyle}"
                        Click="OnAddClick"
                        Margin="0,0,0,5"/>
                <Button x:Name="EditButton"
                        Content="Edit" 
                        Style="{StaticResource SettingsButtonStyle}"
                        Click="OnEditClick"
                        Margin="0,0,0,5"
                        IsEnabled="False"/>
                <Button x:Name="DeleteButton"
                        Content="Delete" 
                        Style="{StaticResource SettingsButtonStyle}"
                        Click="OnDeleteClick"
                        Margin="0,0,0,5"
                        IsEnabled="False"/>
                <Separator Background="#ddd" Margin="0,5"/>
                <Button x:Name="UpButton"
                        Content="Up" 
                        Style="{StaticResource SettingsButtonStyle}"
                        Click="OnMoveUpClick"
                        Margin="0,0,0,5"
                        IsEnabled="False"/>
                <Button x:Name="DownButton"
                        Content="Down" 
                        Style="{StaticResource SettingsButtonStyle}"
                        Click="OnMoveDownClick"
                        IsEnabled="False"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <Border Grid.Row="0" 
                    Background="#f0f0f0" 
                    Padding="12,8" 
                    CornerRadius="4"
                    Cursor="Hand"
                    MouseLeftButtonDown="OnAutoStartClick">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock x:Name="AutoStartTitleText"
                                   Text="开机自启" 
                                   FontSize="14" 
                                   FontWeight="Medium"
                                   Foreground="#333"/>
                        <TextBlock x:Name="AutoStartDescText"
                                   Text="启动 Windows 时自动运行 QuickDock" 
                                   FontSize="11" 
                                   Foreground="#999"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    
                    <Border Grid.Column="1" 
                            x:Name="AutoStartToggle"
                            Width="44" 
                            Height="24" 
                            Background="#ccc"
                            CornerRadius="12"
                            VerticalAlignment="Center">
                        <Border x:Name="AutoStartToggleKnob"
                                Width="20" 
                                Height="20" 
                                Background="White"
                                CornerRadius="10"
                                HorizontalAlignment="Left"
                                Margin="2,0"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" 
                       x:Name="LanguageLabel"
                       Text="Language:" 
                       VerticalAlignment="Center"
                       Foreground="#333"
                       Margin="0,0,10,0"/>
            <ComboBox Grid.Column="1"
                      x:Name="LanguageComboBox"
                      Style="{StaticResource ComboBoxStyle}"
                      SelectionChanged="OnLanguageChanged"/>
        </Grid>

        <Grid Grid.Row="4" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" 
                       x:Name="BackgroundColorLabel"
                       Text="Background:" 
                       VerticalAlignment="Center"
                       Foreground="#333"
                       Margin="0,0,10,0"/>
            <TextBox Grid.Column="1"
                     x:Name="BackgroundColorTextBox"
                     Style="{StaticResource TextBoxStyle}"
                     Text="#1e1e1e"
                     VerticalAlignment="Center"
                     TextChanged="OnBackgroundColorChanged"/>
            <Border Grid.Column="2"
                    x:Name="BackgroundColorPreview"
                    Width="30"
                    Height="25"
                    Background="#1e1e1e"
                    CornerRadius="3"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="5" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" 
                       x:Name="OpacityLabel"
                       Text="Opacity:" 
                       VerticalAlignment="Center"
                       Foreground="#333"
                       Margin="0,0,10,0"/>
            <Slider Grid.Column="1"
                    x:Name="OpacitySlider"
                    Minimum="0.3"
                    Maximum="1.0"
                    TickFrequency="0.1"
                    IsSnapToTickEnabled="True"
                    VerticalAlignment="Center"
                    ValueChanged="OnOpacityChanged"/>
            <TextBlock Grid.Column="2"
                       x:Name="OpacityValue"
                       Text="90%"
                       VerticalAlignment="Center"
                       Foreground="#333"
                       Margin="10,0,0,0"
                       Width="40"/>
        </Grid>

        <Grid Grid.Row="6" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" 
                       x:Name="ScaleLabel"
                       Text="Scale:" 
                       VerticalAlignment="Center"
                       Foreground="#333"
                       Margin="0,0,10,0"/>
            <Slider Grid.Column="1"
                    x:Name="ScaleSlider"
                    Minimum="0.5"
                    Maximum="2.0"
                    TickFrequency="0.1"
                    IsSnapToTickEnabled="True"
                    VerticalAlignment="Center"
                    ValueChanged="OnScaleChanged"/>
            <TextBlock Grid.Column="2"
                       x:Name="ScaleValue"
                       Text="100%"
                       VerticalAlignment="Center"
                       Foreground="#333"
                       Margin="10,0,0,0"
                       Width="40"/>
        </Grid>

        <Grid Grid.Row="7" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" 
                       x:Name="IconSizeLabel"
                       Text="Icon Size:" 
                       VerticalAlignment="Center"
                       Foreground="#333"
                       Margin="0,0,10,0"/>
            <Slider Grid.Column="1"
                    x:Name="IconSizeSlider"
                    Minimum="16"
                    Maximum="64"
                    TickFrequency="4"
                    IsSnapToTickEnabled="True"
                    VerticalAlignment="Center"
                    ValueChanged="OnIconSizeChanged"/>
            <TextBlock Grid.Column="2"
                       x:Name="IconSizeValue"
                       Text="32px"
                       VerticalAlignment="Center"
                       Foreground="#333"
                       Margin="10,0,0,0"
                       Width="40"/>
        </Grid>

        <Grid Grid.Row="8" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" 
                       x:Name="IconSpacingLabel"
                       Text="Icon Spacing:" 
                       VerticalAlignment="Center"
                       Foreground="#333"
                       Margin="0,0,10,0"/>
            <Slider Grid.Column="1"
                    x:Name="IconSpacingSlider"
                    Minimum="0"
                    Maximum="20"
                    TickFrequency="1"
                    IsSnapToTickEnabled="True"
                    VerticalAlignment="Center"
                    ValueChanged="OnIconSpacingChanged"/>
            <TextBlock Grid.Column="2"
                       x:Name="IconSpacingValue"
                       Text="5px"
                       VerticalAlignment="Center"
                       Foreground="#333"
                       Margin="10,0,0,0"
                       Width="40"/>
        </Grid>

        <Grid Grid.Row="9" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" 
                       x:Name="TriggerDelayLabel"
                       Text="Trigger Delay:" 
                       VerticalAlignment="Center"
                       Foreground="#333"
                       Margin="0,0,10,0"/>
            <Slider Grid.Column="1"
                    x:Name="TriggerDelaySlider"
                    Minimum="0"
                    Maximum="2000"
                    TickFrequency="100"
                    IsSnapToTickEnabled="True"
                    VerticalAlignment="Center"
                    ValueChanged="OnTriggerDelayChanged"/>
            <TextBlock Grid.Column="2"
                       x:Name="TriggerDelayValue"
                       Text="500ms"
                       VerticalAlignment="Center"
                       Foreground="#333"
                       Margin="10,0,0,0"
                       Width="50"/>
        </Grid>

        <Grid Grid.Row="10" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" 
                       x:Name="EdgeSizeLabel"
                       Text="Edge Size:" 
                       VerticalAlignment="Center"
                       Foreground="#333"
                       Margin="0,0,10,0"/>
            <Slider Grid.Column="1"
                    x:Name="EdgeSizeSlider"
                    Minimum="1"
                    Maximum="10"
                    TickFrequency="1"
                    IsSnapToTickEnabled="True"
                    VerticalAlignment="Center"
                    ValueChanged="OnEdgeSizeChanged"/>
            <TextBlock Grid.Column="2"
                       x:Name="EdgeSizeValue"
                       Text="1px"
                       VerticalAlignment="Center"
                       Foreground="#333"
                       Margin="10,0,0,0"
                       Width="40"/>
        </Grid>

        <Grid Grid.Row="11" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <CheckBox Grid.Column="0"
                      x:Name="ShowStatusBarCheckBox"
                      Content="Show Status Bar" 
                      Foreground="#333"
                      Checked="OnShowStatusBarChanged"
                      Unchecked="OnShowStatusBarChanged"
                      VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="12" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" 
                       x:Name="WeatherCityLabel"
                       Text="Weather City:" 
                       VerticalAlignment="Center"
                       Foreground="#333"
                       Margin="0,0,10,0"/>
            <TextBox Grid.Column="1"
                     x:Name="WeatherCityTextBox"
                     Style="{StaticResource TextBoxStyle}"
                     VerticalAlignment="Center"
                     TextChanged="OnWeatherCityChanged"/>
        </Grid>

        <StackPanel Grid.Row="13" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button x:Name="SaveButton"
                    Content="Save" 
                    Style="{StaticResource SettingsButtonStyle}"
                    Click="OnSaveClick"
                    Margin="0,0,10,0"/>
            <Button x:Name="CancelButton"
                    Content="Cancel" 
                    Style="{StaticResource SettingsButtonStyle}"
                    Click="OnCancelClick"/>
        </StackPanel>
    </Grid>
</Window>
