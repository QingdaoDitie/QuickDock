<Window x:Class="QuickDock.Windows.ItemEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Item"
        Width="460"
        Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Topmost="True"
        Style="{StaticResource WindowStyle}">
    
    <Grid Margin="18">
        <Border Style="{StaticResource DialogPanelStyle}">
            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,14">
                    <TextBlock x:Name="HeaderTitleText"
                               Text="编辑项目"
                               Style="{StaticResource DialogTitleTextStyle}"/>
                    <TextBlock x:Name="HeaderSubtitleText"
                               Text="配置名称、启动方式、图标与附加参数。"
                               Style="{StaticResource DialogSubtitleTextStyle}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Border Grid.Row="1"
                        Style="{StaticResource DialogCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   x:Name="NameLabel"
                                   Text="Name:"
                                   Style="{StaticResource FieldLabelTextStyle}"/>
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 x:Name="NameTextBox"
                                 Style="{StaticResource TextBoxStyle}"
                                 Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   x:Name="TypeLabel"
                                   Text="Type:"
                                   Style="{StaticResource FieldLabelTextStyle}"/>
                        <ComboBox Grid.Row="1" Grid.Column="1"
                                  x:Name="TypeComboBox"
                                  Style="{StaticResource ComboBoxStyle}"
                                  Margin="0,0,0,10"
                                  SelectionChanged="OnTypeChanged"/>

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   x:Name="PathLabel"
                                   Text="Path:"
                                   Style="{StaticResource FieldLabelTextStyle}"/>
                        <Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     x:Name="PathTextBox"
                                     Style="{StaticResource TextBoxStyle}"/>
                            <Button Grid.Column="1"
                                    Content="..."
                                    Style="{StaticResource SettingsButtonStyle}"
                                    Click="OnBrowseClick"
                                    Margin="8,0,0,0"
                                    Width="34"
                                    x:Name="BrowseButton"/>
                        </Grid>

                        <TextBlock Grid.Row="3" Grid.Column="0"
                                   x:Name="ArgumentsLabel"
                                   Text="Arguments:"
                                   Style="{StaticResource FieldLabelTextStyle}"/>
                        <TextBox Grid.Row="3" Grid.Column="1"
                                 x:Name="ArgumentsTextBox"
                                 Style="{StaticResource TextBoxStyle}"
                                 Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="4" Grid.Column="0"
                                   x:Name="IconLabel"
                                   Text="Icon:"
                                   Style="{StaticResource FieldLabelTextStyle}"/>
                        <Grid Grid.Row="4" Grid.Column="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     x:Name="IconPathTextBox"
                                     Style="{StaticResource TextBoxStyle}"
                                     IsReadOnly="True"/>
                            <Button Grid.Column="1"
                                    x:Name="BrowseIconButton"
                                    Content="..."
                                    Style="{StaticResource SettingsButtonStyle}"
                                    Click="OnBrowseIconClick"
                                    Margin="8,0,0,0"
                                    Width="34"/>
                        </Grid>

                        <Border Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                                x:Name="IconPreviewArea"
                                Background="{StaticResource SecondaryBackgroundBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10"
                                Margin="0,0,0,10"
                                Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <Border Grid.Column="0"
                                        Width="48"
                                        Height="48"
                                        Background="{StaticResource WindowPanelBrush}"
                                        CornerRadius="6">
                                    <Image x:Name="PreviewIconImage"
                                           Stretch="Uniform"
                                           Visibility="Collapsed"/>
                                </Border>
                                
                                <TextBlock Grid.Column="1"
                                           x:Name="PreviewStatusText"
                                           Text=""
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Style="{StaticResource TextBlockStyle}"
                                           Margin="10,0"/>
                                
                                <Button Grid.Column="2"
                                        x:Name="UseIconBtn"
                                        Content="Use"
                                        Style="{StaticResource SuccessButtonStyle}"
                                        Visibility="Collapsed"
                                        Click="OnUseIconClick"
                                        VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Button Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                                x:Name="FetchIconBtn"
                                Content="Fetch Icon from URL"
                                Style="{StaticResource SettingsButtonStyle}"
                                Margin="0,0,0,10"
                                Click="OnFetchIconClick"
                                Visibility="Collapsed"/>

                        <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2">
                            <CheckBox x:Name="RunAsAdminCheckBox"
                                      Content="Run as Administrator"
                                      Style="{StaticResource CheckBoxStyle}"
                                      Margin="0,2,0,0"
                                      VerticalAlignment="Center"/>

                            <CheckBox x:Name="AppendClipboardCheckBox"
                                      Content="Append Clipboard Content"
                                      Style="{StaticResource CheckBoxStyle}"
                                      Margin="0,10,0,0"
                                      VerticalAlignment="Center"
                                      Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,16,0,0">
                    <Button x:Name="OkButton"
                            Content="OK"
                            Width="96"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Click="OnOkClick"
                            Margin="0,0,10,0"/>
                    <Button x:Name="CancelButton"
                            Content="Cancel"
                            Width="96"
                            Style="{StaticResource SettingsButtonStyle}"
                            Click="OnCancelClick"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
