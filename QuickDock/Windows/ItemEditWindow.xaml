<Window x:Class="QuickDock.Windows.ItemEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Item"
        Width="420"
        Height="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Topmost="True"
        Style="{StaticResource WindowStyle}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" 
                   x:Name="NameLabel"
                   Text="Name:" 
                   VerticalAlignment="Center"
                   Style="{StaticResource TextBlockStyle}"/>
        <TextBox Grid.Row="0" Grid.Column="1" 
                 x:Name="NameTextBox"
                 Style="{StaticResource TextBoxStyle}"
                 Margin="0,5"/>

        <TextBlock Grid.Row="1" Grid.Column="0" 
                   x:Name="TypeLabel"
                   Text="Type:" 
                   VerticalAlignment="Center"
                   Style="{StaticResource TextBlockStyle}"/>
        <ComboBox Grid.Row="1" Grid.Column="1" 
                  x:Name="TypeComboBox"
                  Style="{StaticResource ComboBoxStyle}"
                  Margin="0,5"
                  SelectionChanged="OnTypeChanged"/>

        <TextBlock Grid.Row="2" Grid.Column="0" 
                   x:Name="PathLabel"
                   Text="Path:" 
                   VerticalAlignment="Center"
                   Style="{StaticResource TextBlockStyle}"/>
        <Grid Grid.Row="2" Grid.Column="1" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" 
                     x:Name="PathTextBox"
                     Style="{StaticResource TextBoxStyle}"/>
            <Button Grid.Column="1" 
                    Content="..."
                    Style="{StaticResource SettingsButtonStyle}"
                    Click="OnBrowseClick"
                    Margin="5,0,0,0"
                    Width="30"
                    x:Name="BrowseButton"/>
        </Grid>

        <TextBlock Grid.Row="3" Grid.Column="0" 
                   x:Name="ArgumentsLabel"
                   Text="Arguments:" 
                   VerticalAlignment="Center"
                   Style="{StaticResource TextBlockStyle}"/>
        <TextBox Grid.Row="3" Grid.Column="1" 
                 x:Name="ArgumentsTextBox"
                 Style="{StaticResource TextBoxStyle}"
                 Margin="0,5"/>

        <TextBlock Grid.Row="4" Grid.Column="0" 
                   x:Name="IconLabel"
                   Text="Icon:" 
                   VerticalAlignment="Center"
                   Style="{StaticResource TextBlockStyle}"/>
        <Grid Grid.Row="4" Grid.Column="1" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" 
                     x:Name="IconPathTextBox"
                     Style="{StaticResource TextBoxStyle}"
                     IsReadOnly="True"/>
            <Button Grid.Column="1" 
                    x:Name="BrowseIconButton"
                    Content="..."
                    Style="{StaticResource SettingsButtonStyle}"
                    Click="OnBrowseIconClick"
                    Margin="5,0,0,0"
                    Width="30"/>
        </Grid>

        <Border Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                x:Name="IconPreviewArea"
                Background="{StaticResource SecondaryBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="5"
                Padding="10"
                Margin="0,10,0,0"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0"
                        Width="48"
                        Height="48"
                        Background="#30FFFFFF"
                        CornerRadius="5">
                    <Image x:Name="PreviewIconImage"
                           Stretch="Uniform"
                           Visibility="Collapsed"/>
                </Border>
                
                <TextBlock Grid.Column="1"
                           x:Name="PreviewStatusText"
                           Text=""
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Style="{StaticResource TextBlockStyle}"
                           Margin="10,0"/>
                
                <Button Grid.Column="2"
                        x:Name="UseIconBtn"
                        Content="Use"
                        Style="{StaticResource SettingsButtonStyle}"
                        Visibility="Collapsed"
                        Click="OnUseIconClick"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Button Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                x:Name="FetchIconBtn"
                Content="Fetch Icon from URL"
                Style="{StaticResource SettingsButtonStyle}"
                Margin="0,10,0,0"
                Click="OnFetchIconClick"
                Visibility="Collapsed"/>

        <CheckBox Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                  x:Name="RunAsAdminCheckBox"
                  Content="Run as Administrator"
                  Style="{StaticResource CheckBoxStyle}"
                  Margin="0,10,0,0"
                  VerticalAlignment="Center"/>

        <CheckBox Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                  x:Name="AppendClipboardCheckBox"
                  Content="Append Clipboard Content"
                  Style="{StaticResource CheckBoxStyle}"
                  Margin="0,30,0,0"
                  VerticalAlignment="Center"
                  Visibility="Collapsed"/>

        <StackPanel Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button x:Name="OkButton"
                    Content="OK" 
                    Style="{StaticResource SettingsButtonStyle}"
                    Click="OnOkClick"
                    Margin="0,0,10,0"/>
            <Button x:Name="CancelButton"
                    Content="Cancel" 
                    Style="{StaticResource SettingsButtonStyle}"
                    Click="OnCancelClick"/>
        </StackPanel>
    </Grid>
</Window>
