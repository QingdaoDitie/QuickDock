<UserControl x:Class="QuickDock.Controls.StatusControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Cursor="Hand">
    <UserControl.Resources>
        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style x:Key="ResourceLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#777"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style x:Key="ResourceValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#bbb"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>
    </UserControl.Resources>
    
    <Border Background="#1a1a1a" 
            BorderBrush="#333" 
            BorderThickness="1"
            Padding="12,4"
            CornerRadius="4">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0"
                       Text="{Binding WeatherIcon}"
                       FontSize="14"
                       VerticalAlignment="Center"
                       Margin="0,0,5,0"
                       Foreground="#e0e0e0"
                       MouseLeftButtonUp="OnRefreshClick"
                       ToolTip="点击刷新天气"/>
            
            <TextBlock Grid.Column="1"
                       Text="{Binding WeatherText}"
                       Style="{StaticResource StatusTextStyle}"
                       Margin="0,0,10,0"
                       MouseLeftButtonUp="OnRefreshClick"/>
            
            <Border Grid.Column="2"
                    Width="1"
                    Background="#444"
                    Margin="0,2,8,2"/>
            
            <TextBlock Grid.Column="3"
                       Text="CPU"
                       Style="{StaticResource ResourceLabelStyle}"
                       Margin="0,0,3,0"/>
            
            <TextBlock Grid.Column="4"
                       Style="{StaticResource ResourceValueStyle}">
                <TextBlock.Text>
                    <MultiBinding StringFormat="{}{0}%">
                        <Binding Path="CpuPercent"/>
                    </MultiBinding>
                </TextBlock.Text>
            </TextBlock>
            
            <TextBlock Grid.Column="5"
                       Text="MEM"
                       Style="{StaticResource ResourceLabelStyle}"
                       Margin="8,0,3,0"/>
            
            <TextBlock Grid.Column="6"
                       Style="{StaticResource ResourceValueStyle}">
                <TextBlock.Text>
                    <MultiBinding StringFormat="{}{0}%">
                        <Binding Path="MemPercent"/>
                    </MultiBinding>
                </TextBlock.Text>
            </TextBlock>
            
            <TextBlock Grid.Column="7"
                       Text="GPU"
                       Style="{StaticResource ResourceLabelStyle}"
                       Margin="8,0,3,0"/>
            
            <TextBlock Grid.Column="8"
                       Style="{StaticResource ResourceValueStyle}">
                <TextBlock.Text>
                    <MultiBinding StringFormat="{}{0}%">
                        <Binding Path="GpuPercent"/>
                    </MultiBinding>
                </TextBlock.Text>
            </TextBlock>
        </Grid>
    </Border>
</UserControl>
