<Window x:Class="QuickDock.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:QuickDock.Controls"
        Title="QuickDock"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="Auto"
        Height="Auto"
        SizeToContent="WidthAndHeight"
        AllowDrop="True"
        DragEnter="OnWindowDragEnter"
        DragOver="OnWindowDragOver"
        Drop="OnWindowDrop"
        PreviewMouseLeftButtonDown="OnWindowPreviewMouseLeftButtonDown"
        PreviewMouseMove="OnWindowPreviewMouseMove">
    
    <Window.Resources>
    </Window.Resources>

    <Grid x:Name="MainGrid">
        <StackPanel>
            <Border x:Name="DockBorder"
                    Style="{StaticResource DockPanelStyle}"
                    Padding="10,8"
                    HorizontalAlignment="Center"
                    MouseLeave="OnDockMouseLeave">
                <StackPanel Orientation="Horizontal">
                    <local:StatusControl x:Name="StatusControl" Margin="0,0,10,0"/>
                    <Border x:Name="StatusBarSeparator" Width="1" Background="{StaticResource BorderBrush}" Margin="0,4,10,4"/>
                    <ItemsControl x:Name="DockItems" 
                                  ItemsSource="{Binding Items}"
                                  AllowDrop="True"
                                  DragOver="OnDockItemsDragOver"
                                  Drop="OnDockItemsDrop">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel x:Name="ItemsPanel" Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <local:DockItemControl x:Name="DockItem"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button x:Name="ToolsButton"
                            Style="{StaticResource DockItemButtonStyle}"
                            Click="OnToolsButtonClick"
                            ToolTip="工具集合"
                            Visibility="Collapsed">
                        <Grid>
                            <Image x:Name="ToolsButtonIcon"
                                   Width="{Binding ToolIconSize}"
                                   Height="{Binding ToolIconSize}"
                                   Stretch="Uniform"
                                   Visibility="Collapsed"/>
                            <TextBlock x:Name="ToolsButtonFallbackText"
                                       Text="T"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </Grid>
                    </Button>
                </StackPanel>
            </Border>
            
            <Border x:Name="ToolsPanel"
                    Style="{StaticResource DockPanelStyle}"
                    Padding="10,8"
                    HorizontalAlignment="Center"
                    Visibility="Collapsed"
                    Height="0"
                    MaxWidth="{Binding ElementName=DockBorder, Path=ActualWidth}"
                    ClipToBounds="True">
                <ScrollViewer HorizontalAlignment="Center"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              CanContentScroll="False"
                              PanningMode="HorizontalOnly">
                    <ItemsControl x:Name="ToolsItems" 
                                  ItemsSource="{Binding Tools}"
                                  HorizontalAlignment="Left"
                                  AllowDrop="True"
                                  DragOver="OnToolsItemsDragOver"
                                  Drop="OnToolsItemsDrop">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <local:DockItemControl x:Name="ToolItem"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </StackPanel>
    </Grid>
</Window>
